# Anthropic Admin API Key (obtain from https://console.anthropic.com/)
ADMIN_API_KEY=sk-ant-admin-...

# Claude Code home directory (default: ~/.claude/projects)
CLAUDE_CODE_HOME=~/.claude/projects

# SQLite database path
SQLITE_DB_PATH=./data/tokens.db

# API polling interval (seconds, default: 60)
POLLING_INTERVAL=60

# Claude Code session reset window (hours, default: 5)
SESSION_RESET_HOURS=5

# Cost alert thresholds (comma-separated decimals: 0.8,0.9,0.95)
COST_ALERT_THRESHOLDS=0.8,0.9,0.95

# Backend server port
BACKEND_PORT=8000

# Frontend URL (for CORS - local dev: http://localhost:3000)
FRONTEND_URL=http://localhost:3000
